params {
    config_profile_description = 'University College London Myriad cluster'
    config_profile_contact     = 'Chris Wyatt (ucbtcdr@ucl.ac.uk), Fernando Duarte (f.frutos@ucl.ac.uk)'
    config_profile_url         = 'https://www.rc.ucl.ac.uk/docs/Clusters/Myriad/'
}

// No shared .sif store on Myriad — pull from GHCR and let singularity.cacheDir cache the images
params.container_registry = 'ghcr.io/uclorengogroup'
params.container_tag      = 'main-latest'

// Exclude specific nodes from GPU jobs. Populate with Myriad hostnames (e.g. node-l00a-001) if needed.
// See https://www.rc.ucl.ac.uk/docs/Clusters/Myriad/#requesting-multiple-and-specific-types-of-gpu
// for requesting specific GPU node types (-ac allow=EF for V100, -ac allow=L for A100) instead.
params.excluded_gpu_nodes = []

executor {
    name            = 'sge'
    queueSize       = 100      // Limit number of jobs sent to qsub (max is 1000, but in case user submits more than one job)
    submitRateLimit = '10/1s'  // Submit max 10 jobs per second. To ease pressure on scheduler.
}

// ========== PROCESS SETTINGS ==========
process {

    cache     = 'lenient'
    container = "${params.container_registry}/domain-annotation-pipeline-script:${params.container_tag}"
    stageInMode  = 'copy'
    stageOutMode = 'copy'

    beforeScript = '''
    echo "========== TASK START =========="
    echo "Timestamp        : $(date)"
    echo "Hostname         : $(hostname)"
    echo "SGE Job ID       : $JOB_ID"
    echo "SGE Task ID      : $SGE_TASK_ID"
    echo "Queue            : $QUEUE"
    echo "Working Dir      : $(pwd)"
    echo "User             : $(whoami)"
    echo "CPU cores        : ${NSLOTS:-unknown}"
    echo "GPU devices      : $CUDA_VISIBLE_DEVICES"
    echo "==============================="
    env | grep '^NXF_' | sort
    '''
    // ---------- LABEL PROFILES ----------

    // Local processes
    withLabel: local {
        executor = 'local'
    }

    // Generic SGE CPU jobs
    withLabel: sge_low {
        executor = 'sge'
        penv     = { task.cpus > 1 ? 'smp' : '' }

        // Common SGE options for non-GPU jobs
        clusterOptions = {
            def mem  = task.memory ? task.memory.mega : 2000
            def cpus = task.cpus
            def time = task.time ? task.time.toString() : '23h'
            // Myriad requests memory per slot, not per job
            def memoryPerCpu = mem / cpus
            def opts = "-S /bin/bash -l mem=${memoryPerCpu}M,h_rt=${time.replace('h', ':00:00')}"
            if (cpus > 2) opts += " -R y"
            return opts
        }
    }

    // Generic SGE GPU jobs
    withLabel: sge_gpu_high {
        containerOptions = '--nv'  // required for GPU support in containers
        executor         = 'sge'
        penv             = { task.cpus > 1 ? 'smp' : '' }

        // Common SGE options for GPU jobs: use task.memory, add gpu + h_rt
        clusterOptions = {
            def mem  = task.memory ? task.memory.mega : 16000
            def cpus = task.cpus
            def time = task.time ? task.time.toString() : '23h'
            def memoryPerCpu = mem / cpus
            def opts = "-S /bin/bash -l mem=${memoryPerCpu}M,h_rt=${time.replace('h', ':00:00')} -l gpu=1"

            // Exclude specific nodes from GPU jobs
            if (params.excluded_gpu_nodes) {
                def excluded = params.excluded_gpu_nodes.collect { node -> "!${node}" }.join('|')
                opts += " -l h='${excluded}'"
            }

            if (cpus > 1) opts += " -R y"
            return opts
        }
    }

    // ---------- DEFAULT CONTAINERS ----------

    withName: '.*' {
        container = "${params.container_registry}/domain-annotation-pipeline-script:${params.container_tag}"
    }

    withName: 'foldseek_create_db|foldseek_run_convertalis' {
        container     = "${params.container_registry}/domain-annotation-pipeline-foldseek:${params.container_tag}"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 4.GB : task.attempt == 2 ? 15.GB : 25.GB }
        cpus          = 1
    }

    // ---------- PROCESS-SPECIFIC OVERRIDES ----------
    // ---------- SCRIPT/DEFAULT ------------
    withName: foldseek_run_foldseek {
        container     = "${params.container_registry}/domain-annotation-pipeline-foldseek:${params.container_tag}"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 15.GB : task.attempt == 2 ? 31.GB : 45.GB }
        cpus          = 2 //must keep cpus to a sensible number to prevent run_foldseek failure
    }

    withName: foldseek_process_results {
        container     = "${params.container_registry}/domain-annotation-pipeline-script:${params.container_tag}"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 1.GB : task.attempt == 2 ? 2.GB : 8.GB }
    }

    withName: chop_pdb_from_zip {
        container     = "${params.container_registry}/domain-annotation-pipeline-script:${params.container_tag}"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 1.GB : task.attempt == 2 ? 2.GB : 8.GB }
    }

    withName: collect_results {
        container     = "${params.container_registry}/domain-annotation-pipeline-script:${params.container_tag}"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 4.GB : task.attempt == 2 ? 8.GB : 12.GB }
    }

    withName: get_uniprot_data {
        maxForks      = 2
        errorStrategy = 'retry'
        maxRetries    = 5
        memory        = { task.attempt == 1 ? 2.GB : task.attempt == 2 ? 4.GB : 8.GB }
    }

    withName: normalise_af_ids {
        executor = 'local'
        container = null
    }

    withName: 'download_bcif_from_afdb' {
        container = "${params.container_registry}/domain-annotation-pipeline-script:${params.container_tag}"
        time      = '23h'
        memory    = 7.GB
        maxForks  = 50
    }

    withName: 'prepare_pdb_from_af_bcif' {
        container  = "${params.container_registry}/domain-annotation-pipeline-script:${params.container_tag}"
        time       = '23h'
        memory     = { task.attempt == 1 ? 23.GB : 31.GB }
        maxRetries = 3
    }

    withName: transform_consensus {
        executor      = 'local'
    }

    withName: filter_pdb_from_zip {
        executor      = 'local'
        errorStrategy = 'retry'
        maxRetries    = 3
    }

    // ---------- TED-TOOLS ------------
    withName: run_ted_segmentation {
        container     = "${params.container_registry}/domain-annotation-pipeline-ted-tools:${params.container_tag}"
        errorStrategy = 'retry'
        maxRetries    = 4
        // 1st attempt: 31 GB, 2nd: 45 GB, 3rd: 63 GB.
        memory        = { task.attempt == 1 ? 31.GB : task.attempt == 2 ? 45.GB : 63.GB }
        time          = '23h'    // used for documentation; h_rt fixed in label as before
    }

    withName: run_domain_quality {
        container     = "${params.container_registry}/domain-annotation-pipeline-ted-tools:${params.container_tag}"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 15.GB : task.attempt == 2 ? 23.GB : 31.GB }
    }

    // ---------- CATH-AF-CLI ------------
    withName: run_stride {
        container     = "${params.container_registry}/domain-annotation-pipeline-cath-af-cli:${params.container_tag}"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 1.GB : task.attempt == 2 ? 2.GB : 8.GB }
        time          = '12h'

    }

    withName: create_md5 {
        container     = "${params.container_registry}/domain-annotation-pipeline-cath-af-cli:${params.container_tag}"
    }

    withName: run_measure_globularity {
        container     = "${params.container_registry}/domain-annotation-pipeline-cath-af-cli:${params.container_tag}"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 2.GB : task.attempt == 2 ? 4.GB : 8.GB }
        time          = '12h'
    }
}

// ========== SINGULARITY SETTINGS ==========
singularity {
    enabled      = true
    autoMounts   = true
    cacheDir     = "${System.getenv('HOME')}/Scratch/.apptainer/pull"
    envWhitelist = 'CUDA_VISIBLE_DEVICES,SINGULARITYENV_CUDA_VISIBLE_DEVICES'
    runOptions   = "--bind ${launchDir}:/launchDir:ro --bind ${System.getenv('HOME')},${System.getenv('PWD')} --no-mount /scratch --writable-tmpfs"
}
