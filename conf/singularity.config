params.singularity_image_dir = '/SAN/orengolab/bfvd/singularity_images'
params.scratch_dir = "/state/partition1/scratch0"
params.project = params.project ?: 'cath'

// Exclude specific nodes from GPU jobs
params.excluded_gpu_nodes = ['hoots-207-1.local']

executor {
    name = 'sge'
}

// ========== PROCESS SETTINGS ==========
process {

    cache = 'lenient'
    container = "${params.singularity_image_dir}/domain-annotation-pipeline-script_latest.sif"
    stageInMode = 'copy'
    stageOutMode = 'copy'

    beforeScript = '''
    echo "========== TASK START =========="
    echo "Timestamp        : $(date)"
    echo "Hostname         : $(hostname)"
    echo "SGE Job ID       : $JOB_ID"
    echo "SGE Task ID      : $SGE_TASK_ID"
    echo "Queue            : $QUEUE"
    echo "Working Dir      : $(pwd)"
    echo "User             : $(whoami)"
    echo "CPU cores        : ${NSLOTS:-unknown}"
    echo "GPU devices      : $CUDA_VISIBLE_DEVICES"
    echo "==============================="
    env | grep '^NXF_' | sort
    '''
    // ---------- LABEL PROFILES ----------

    // Local processes
    withLabel: local {
        executor = 'local'
    }

    // Generic SGE CPU jobs
    withLabel: sge_low {
        scratch  = params.scratch_dir ?: false
        executor = 'sge'
        penv     = { task.cpus > 1 ? 'smp' : '' }

        // Common SGE options for non-GPU jobs
        clusterOptions = {
            def mem  = task.memory ? task.memory.toMega() : '2000'
            def cpus = task.cpus
            def scratchSpace = task.ext.scratchSpace ? task.ext.scratchSpace.toMega() : '1000'
            def time = task.time ? task.time.toString() : '23h'
            def opts = "-P ${params.project} -S /bin/bash -l tmem=${mem}M,h_vmem=${mem}M,h_rt=${time.replace('h', ':00:00')},tscratch=${scratchSpace}M,scratch0free=${scratchSpace}M"
            // AVX2-only for foldseek processes
            if( task.process in ['foldseek_create_db','foldseek_run_foldseek','foldseek_run_convertalis'] ) {
                opts += " -l avx2=yes"
                }
            if (cpus > 2) opts += " -R y"
            return opts
        }
    }

    // Generic SGE GPU jobs
    withLabel: sge_gpu_high {
        containerOptions = '--nv --env CUDA_VISIBLE_DEVICES=$CUDA_VISIBLE_DEVICES'  // required for GPU support in containers
        scratch          = params.scratch_dir ?: false
        executor         = 'sge'
        penv             = { task.cpus > 1 ? 'smp' : '' }

        // Common SGE options for GPU jobs: use task.memory, add gpu + h_rt
        clusterOptions = {
            def mem  = task.memory ? task.memory.toMega() : '16000'
            def cpus = task.cpus
            def scratchSpace = task.ext.scratchSpace ? task.ext.scratchSpace.toMega() : '1000'
            def time = task.time ? task.time.toString() : '23h'
            def opts = "-P ${params.project} -S /bin/bash -l tmem=${mem}M,h_vmem=${mem}M -l gpu=true -l h_rt=${time.replace('h', ':00:00')},tscratch=${scratchSpace}M,scratch0free=${scratchSpace}M"
            
            // Exclude specific nodes from GPU jobs
            if (params.excluded_gpu_nodes) {
                def excluded = params.excluded_gpu_nodes.collect { node -> "!${node}" }.join('|')
                opts += " -l h='${excluded}'"
            }
            
            if (cpus > 1) opts += " -R y"
            return opts
        }
    }

    // ---------- DEFAULT CONTAINERS ----------

    withName: 'foldseek_create_db|foldseek_run_convertalis' {
        container     = "${params.singularity_image_dir}/domain-annotation-pipeline-foldseek_latest.sif"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 8.GB : task.attempt == 2 ? 15.GB : 25.GB }
        cpus          = 1
    }

    // ---------- PROCESS-SPECIFIC OVERRIDES ----------
    // ---------- SCRIPT/DEFAULT ------------
    withName: foldseek_run_foldseek {
        container     = "${params.singularity_image_dir}/domain-annotation-pipeline-foldseek_latest.sif"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 15.GB : task.attempt == 2 ? 31.GB : 45.GB }
        cpus          = 2 //must keep cpus to a sensible number to prevent run_foldseek failure
    }

    withName: foldseek_process_results {
        container     = "${params.singularity_image_dir}/domain-annotation-pipeline-script_latest.sif"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 1.GB : task.attempt == 2 ? 2.GB : 8.GB }
    }

    withName: chop_pdb_from_zip {
        container     = "${params.singularity_image_dir}/domain-annotation-pipeline-script_latest.sif"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 2.GB : task.attempt == 2 ? 4.GB : 8.GB }
    }

    withName: collect_results {
        container     = "${params.singularity_image_dir}/domain-annotation-pipeline-script_latest.sif"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 4.GB : task.attempt == 2 ? 8.GB : 12.GB }
    }

    withName: get_uniprot_data {
        container     = "${params.singularity_image_dir}/domain-annotation-pipeline-script_latest.sif"
        maxForks      = 2
        errorStrategy = 'retry'
        maxRetries    = 5
        memory        = { task.attempt == 1 ? 2.GB : task.attempt == 2 ? 4.GB : 8.GB }
    }

    withName: normalise_af_ids {
        executor = 'local'
        container = null
    }

    withName: 'download_bcif_from_afdb' {
        container        = "${params.singularity_image_dir}/domain-annotation-pipeline-script_latest.sif"
        time             = '23h'
        memory           = 7.GB
        maxForks         = 50
        ext.scratchSpace = 20.GB
    }

    withName: 'prepare_pdb_from_af_bcif' {
        container        = "${params.singularity_image_dir}/domain-annotation-pipeline-script_latest.sif"
        time             = '23h'
        memory           = { task.attempt == 1 ? 23.GB : 31.GB }
        ext.scratchSpace = 20.GB
        maxRetries       = 3
    }

    withName: transform_consensus {
        container     = "${params.singularity_image_dir}/domain-annotation-pipeline-script_latest.sif"
        executor      = 'local'
        scratch       = false
    }

    withName: filter_pdb_from_zip {
        container     = "${params.singularity_image_dir}/domain-annotation-pipeline-script_latest.sif"
        executor      = 'local'
        errorStrategy = 'retry'
        scratch       = false
        maxRetries    = 3
    }

    withName: collect_results_final {
        container     = "${params.singularity_image_dir}/domain-annotation-pipeline-script_latest.sif"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 8.GB : task.attempt == 2 ? 16.GB : 32.GB }
    }
    
    withName: 'create_input_from_zip|chunk_by_zip|heavy_chunk_by_zip|light_chunk_consensus_by_zip|run_plddt|join_plddt_md5' {
        container     = "${params.singularity_image_dir}/domain-annotation-pipeline-script_latest.sif"
        executor      = 'local'
        scratch       = false
    }

    // ---------- TED-TOOLS ------------
    withName: run_ted_segmentation {
        container     = "${params.singularity_image_dir}/domain-annotation-pipeline-ted-tools_latest.sif"
        errorStrategy = 'retry'
        maxRetries    = 4
        // 1st attempt: 31 GB, 2nd: 45 GB, 3rd: 63 GB.
        memory        = { task.attempt == 1 ? 32.GB : task.attempt == 2 ? 48.GB : 63.GB }
        time          = '23h'    // used for documentation; h_rt fixed in label as before
    }

    withName: run_domain_quality {
        container     = "${params.singularity_image_dir}/domain-annotation-pipeline-ted-tools_latest.sif"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 31.GB : task.attempt == 2 ? 45.GB : 63.GB }
    }

    // ---------- CATH-AF-CLI ------------
    withName: run_stride {
        container     = "${params.singularity_image_dir}/domain-annotation-pipeline-cath-af-cli_latest.sif"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 1.GB : task.attempt == 2 ? 2.GB : 8.GB }
        time          = '12h'
        
    }

    withName: create_md5 {
        container     = "${params.singularity_image_dir}/domain-annotation-pipeline-cath-af-cli_latest.sif"
        executor      = 'local'
    }

    withName: run_measure_globularity {
        container     = "${params.singularity_image_dir}/domain-annotation-pipeline-cath-af-cli_latest.sif"
        errorStrategy = 'retry'
        maxRetries    = 3
        memory        = { task.attempt == 1 ? 4.GB : task.attempt == 2 ? 8.GB : 12.GB }
        time          = '12h'
    }
}

// ========== SINGULARITY SETTINGS ==========
singularity {
    enabled      = true
    autoMounts   = true
    envWhitelist = 'CUDA_VISIBLE_DEVICES,SINGULARITYENV_CUDA_VISIBLE_DEVICES'

    // note: will need to override this if scratch_dir is false (cannot use a closure here) 
    runOptions   = "--bind ${launchDir}:/launchDir:ro --bind ${params.scratch_dir}"
}
