//params.scratch_dir = "/SAN/orengolab/bfvd/nextflow_scratch/${System.getenv('USER')}"
//params.scratch_dir = true
params.scratch_dir = "/state/partition1/scratch0"
params.project = params.project ?: 'cath'

// Exclude specific nodes from GPU jobs
params.excluded_gpu_nodes = ['bubba-213-3.local']

executor {
    name = 'sge'
}

// ========== PROCESS SETTINGS ==========
process {

    cache = 'lenient'
    stageInMode = 'copy'
    stageOutMode = 'copy'

    beforeScript = '''
    echo "========== TASK START =========="
    echo "Timestamp        : $(date)"
    echo "Hostname         : $(hostname)"
    echo "SGE Job ID       : $JOB_ID"
    echo "SGE Task ID      : $SGE_TASK_ID"
    echo "Queue            : $QUEUE"
    echo "Working Dir      : $(pwd)"
    echo "User             : $(whoami)"
    echo "CPU cores        : ${NSLOTS:-unknown}"
    echo "GPU devices      : $CUDA_VISIBLE_DEVICES"
    echo "==============================="
    env | grep '^NXF_' | sort
    '''
    // ---------- LABEL PROFILES ----------

    // Local processes
    withLabel: local {
        executor = 'local'
    }

    // Generic SGE CPU jobs
    withLabel: sge_low {
        scratch  = params.scratch_dir ?: false
        executor = 'sge'
        penv     = { task.cpus > 1 ? 'smp' : '' }

        // Common SGE options for non-GPU jobs
        clusterOptions = {
            def mem  = task.memory ? task.memory.mega : '2000'
            def cpus = task.cpus
            def scratchSpace = task.ext.scratchSpace ? task.ext.scratchSpace.mega : '1000'
            def time = task.time ? task.time.toString() : '23h'
            def opts = "-P ${params.project} -S /bin/bash -l tmem=${mem}M,h_vmem=${mem}M,h_rt=${time.replace('h', ':00:00')},tscratch=${scratchSpace}M,scratch0free=${scratchSpace}M"
            // AVX2-only for foldseek processes
            if( task.process in ['foldseek_create_db','foldseek_run_foldseek','foldseek_run_convertalis'] ) {
                opts += " -l avx2=yes"
                }
            if (cpus > 2) opts += " -R y"
            return opts
        }
    }

    // Generic SGE GPU jobs
    withLabel: sge_gpu_high {
        containerOptions = '--nv --env CUDA_VISIBLE_DEVICES=$CUDA_VISIBLE_DEVICES'  // required for GPU support in containers
        scratch          = params.scratch_dir ?: false
        executor         = 'sge'
        penv             = { task.cpus > 1 ? 'smp' : '' }

        // Common SGE options for GPU jobs: use task.memory, add gpu + h_rt
        clusterOptions = {
            def mem  = task.memory ? task.memory.mega : '16000'
            def cpus = task.cpus
            def scratchSpace = task.ext.scratchSpace ? task.ext.scratchSpace.mega : '1000'
            def time = task.time ? task.time.toString() : '23h'
            def opts = "-P ${params.project} -S /bin/bash -l tmem=${mem}M,h_vmem=${mem}M -l gpu=true -l h_rt=${time.replace('h', ':00:00')},tscratch=${scratchSpace}M,scratch0free=${scratchSpace}M"
            
            // Exclude specific nodes from GPU jobs
            if (params.excluded_gpu_nodes) {
                def excluded = params.excluded_gpu_nodes.collect { node -> "!${node}" }.join('|')
                opts += " -l h='${excluded}'"
            }
            
            if (cpus > 1) opts += " -R y"
            return opts
        }
    }
}

// ========== SINGULARITY CS CLUSTER SETTINGS ==========
singularity {
    // note: will need to override this if scratch_dir is false (cannot use a closure here) 
    runOptions   = "--bind ${launchDir}:/launchDir:ro --bind ${params.scratch_dir}"
}